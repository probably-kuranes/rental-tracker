# Copy to .env for local use (never commit the real .env).
# On Railway, set these as service Variables instead.

# --- Database ---
# Local SQLite (development):
DATABASE_URL=sqlite:///rental_tracker.db
# Railway PostgreSQL (production): DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Gmail (IMAP with an app password; no OAuth) ---
# The mailbox where Mid South correspondence arrives:
GMAIL_USER=mascariproperties@gmail.com
# Generate at https://myaccount.google.com/apppasswords (requires 2FA):
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Gmail search query that identifies owner statements
GMAIL_SEARCH_QUERY=(from:midsouthbestrentals.com OR from:mascari.david@gmail.com) "Owner Statement" has:attachment

# Statement ingest looks back to this date (Gmail syntax)
STATEMENT_SINCE=2025/01/01

# The inbox digest covers this many days (first backfill uses --since instead)
INBOX_LOOKBACK_DAYS=7

# Label applied to handled emails
PROCESSED_LABEL=RentalTracker/Processed

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Optional. Defaults to claude-opus-4-8.
# LLM_MODEL=claude-opus-4-8

# --- Email delivery (Resend HTTPS API; Railway blocks outbound SMTP) ---
RESEND_API_KEY=re_xxxxx
# Without a verified domain, Resend only delivers to the account owner's email:
EMAIL_TO=mascari.david@gmail.com
# EMAIL_FROM=Rental Tracker <onboarding@resend.dev>
