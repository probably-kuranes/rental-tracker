# Database connection
# For local SQLite (development):
DATABASE_URL=sqlite:///rental_tracker.db
# For Railway PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@host:5432/rental_tracker

# Gmail API configuration
# Local development: use file paths
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
# Railway/cloud: use base64-encoded env vars instead
# GMAIL_CREDENTIALS_B64=<output of: base64 < credentials.json>
# GMAIL_TOKEN_B64=<output of: base64 < token.json>

GMAIL_SEARCH_QUERY=from:midsouthbestrentals.com subject:"Owner Statement" has:attachment

# Email to monitor (your Gmail address)
GMAIL_USER_EMAIL=your-email@gmail.com

# Claude API (for future LLM integration)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Processing settings
PROCESSED_LABEL=RentalTracker/Processed
DOWNLOAD_DIR=./downloads
